<Window x:Class="ZynnChat.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ZynnChat"
        Height="700"
        Width="1100"
        Background="#2f3136">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDE -->
        <Grid Grid.Column="0" Background="#2f3136">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition/>
                <RowDefinition Height="80"/>
            </Grid.RowDefinitions>

            <!-- TABS -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Friends"
                        Width="100"
                        Margin="5"
                        Click="ShowFriends_Click"/>
                <Button Content="Channels"
                        Width="100"
                        Margin="5"
                        Click="ShowChannels_Click"/>
            </StackPanel>

            <!-- FRIENDS -->
            <StackPanel x:Name="FriendsPanel"
                        Grid.Row="1"
                        Margin="10">

                <TextBlock Text="Friends"
                           Foreground="White"
                           FontSize="18"
                           Margin="0,0,0,10"/>

                <ListBox x:Name="FriendsList"
                         Background="#40444b"
                         Foreground="White"
                         BorderThickness="0"
                         SelectionChanged="FriendsList_SelectionChanged"/>
            </StackPanel>

            <!-- SERVERS -->
            <StackPanel x:Name="ChannelsPanel"
                        Grid.Row="1"
                        Margin="10"
                        Visibility="Collapsed">

                <TextBlock Text="Servers"
                           Foreground="White"
                           FontSize="18"
                           Margin="0,0,0,10"/>

                <Button Content="+ Opret server"
                        Margin="0,0,0,10"
                        Click="CreateServer_Click"/>

                <ListBox x:Name="ServerList"
                         Background="#40444b"
                         Foreground="White"
                         BorderThickness="0"
                         SelectionChanged="ServerList_SelectionChanged"/>
            </StackPanel>

            <!-- USER BAR -->
            <Border Grid.Row="2"
                    Background="#23272a"
                    Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>

                    <Ellipse x:Name="ProfileEllipse"
                             Width="40"
                             Height="40"/>

                    <StackPanel Grid.Column="1"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="BottomUsername"
                                   Text="User"
                                   Foreground="White"
                                   FontWeight="Bold"/>
                        <TextBlock Text="Online"
                                   Foreground="#23a559"
                                   FontSize="12"/>
                    </StackPanel>

                    <TextBlock Grid.Column="2"
                               Text="⚙"
                               FontSize="18"
                               Foreground="White"
                               Cursor="Hand"
                               MouseLeftButtonUp="OpenSettings_Click"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>

        <!-- RIGHT SIDE -->
        <Grid Grid.Column="1" Background="#36393f">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition Height="70"/>
            </Grid.RowDefinitions>

            <ListBox x:Name="ChatList"
                     Background="#36393f"
                     Foreground="White"
                     BorderThickness="0"
                     Padding="10"/>

            <!-- CHAT INPUT -->
            <Grid Grid.Row="1" Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="ChatInput"
                         Grid.Column="0"
                         Margin="0,0,10,0"
                         KeyDown="ChatInput_KeyDown"/>

                <Button Content="Send"
                        Grid.Column="1"
                        Click="Send_Click"/>
            </Grid>

            <!-- SETTINGS OVERLAY -->
            <Grid x:Name="SettingsOverlay"
                  Background="#CC000000"
                  Visibility="Collapsed">

                <Border Width="500"
                        Height="400"
                        Background="#2b2d31"
                        CornerRadius="10"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Padding="20">

                    <StackPanel>
                        <TextBlock Text="Indstillinger"
                                   Foreground="White"
                                   FontSize="22"
                                   Margin="0,0,0,20"/>

                        <TextBlock Text="Brugernavn"
                                   Foreground="#b5bac1"/>

                        <TextBox x:Name="SettingsUsernameBox"
                                 Margin="0,5,0,20"/>

                        <Button Content="Upload profilbillede"
                                Click="UploadProfile_Click"
                                Margin="0,0,0,20"/>

                        <Button Content="Gem"
                                Click="SaveSettings_Click"
                                Margin="0,0,0,10"/>

                        <Button Content="Luk"
                                Click="CloseSettings_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
